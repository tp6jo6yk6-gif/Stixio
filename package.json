{
  "name": "stixio",
  "version": "1.0.0-rc.1",
  "private": true,
  "description": "Stixio is a fast sticker production workspace for creators.",
  "type": "module",
  "scripts": {
    "prepare:vendor": "node scripts/prepare-vendor.mjs",
    "postinstall": "npm run prepare:vendor",
    "dev": "npx serve .",
    "preview:local": "npx serve . -l 4173",
    "preview:test": "serve . -l 4173",
    "build": "npm run prepare:vendor && node scripts/build-static.js",
    "preview": "npx serve dist",
    "preview:build": "npm run build && npx serve dist -l 4173",
    "parity:extract": "node scripts/extract-legacy-html.mjs",
    "test": "node --test tests/**/*.test.js",
    "test:e2e:layout": "playwright test --config=playwright.layout.config.js",
    "test:e2e:refine": "playwright test --config=playwright.refine.config.js",
    "test:e2e:review": "playwright test --config=playwright.review.config.js",
    "test:e2e:package": "playwright test --config=playwright.package.config.js",
    "test:e2e:project": "playwright test --config=playwright.project.config.js",
    "test:e2e:destination": "playwright test --config=playwright.destination.config.js",
    "test:e2e:parity": "playwright test --config=playwright.parity.config.js",
    "test:e2e:smoke": "playwright test --config=playwright.smoke.config.js",
    "ci": "npm run test && npm run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "serve": "^14.2.5"
  },
  "keywords": [
    "stixio",
    "sticker",
    "sticker-editor",
    "image-editor",
    "sticker-workshop"
  ],
  "author": "Stixio",
  "license": "UNLICENSED"
}
